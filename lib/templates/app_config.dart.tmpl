import 'package:dartapi_core/dartapi_core.dart' as core;

/// Project-specific configuration for {{projectName}}.
///
/// Extends [core.AppConfig] from dartapi_core which provides all common fields
/// (port, debug, logLevel, dbHost, jwtAccessSecret, corsOrigin, etc.).
///
/// Add application-specific environment variables here:
///
/// ```dart
/// String get stripeKey => env('STRIPE_KEY');
/// int get maxFileUploadMb => envInt('MAX_FILE_UPLOAD_MB', defaultValue: 10);
/// ```
class AppConfig extends core.AppConfig {
  AppConfig({super.environment});

  // Override dbName to include the project name.
  @override
  String get dbName =>
      env('DB_NAME', defaultValue: '{{projectName}}_${appEnv.name}');
}
