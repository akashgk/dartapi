import 'dart:io';
import 'dart:isolate';

import 'package:dartapi_db/dartapi_db.dart';
import 'package:{{projectName}}/src/config/app_config.dart';
import 'package:{{projectName}}/src/config/env_loader.dart';
import 'package:{{projectName}}/src/core/bootstrap.dart';

/// Entry point for extra isolates spawned by `dartapi run --isolates=N`.
Future<void> _isolateEntry(int port) => _startApp(port, shared: true);

Future<void> main(List<String> args) async {
  final config = AppConfig(environment: _loadEnv());
  config.validateForProduction();

  // Priority: --port flag > PORT env var > config default (8080)
  int port = config.port;
  for (var i = 0; i < args.length; i++) {
    if (args[i] == '--port' && i + 1 < args.length) {
      port = int.tryParse(args[i + 1]) ?? port;
      break;
    } else if (args[i].startsWith('--port=')) {
      port = int.tryParse(args[i].split('=')[1]) ?? port;
      break;
    }
  }

  // ISOLATES=N (or `dartapi run --isolates=N`) spawns N isolates on the same
  // port. Each gets its own event loop and DB connections.
  final isolates = int.tryParse(Platform.environment['ISOLATES'] ?? '1') ?? 1;
  if (isolates > 1) {
    for (var i = 0; i < isolates - 1; i++) {
      await Isolate.spawn(_isolateEntry, port);
    }
  }

  await _startApp(port, shared: isolates > 1);
}

Future<void> _startApp(int port, {bool shared = false}) async {
  final config = AppConfig(environment: _loadEnv());

  // ── Database (optional) ────────────────────────────────────────────────────
  // DB_ENABLED=false (the dev default) → in-memory repos, no DB needed.
  // DB_ENABLED=true  → PostgreSQL; swap DbType.postgres for mysql/sqlite.
  DartApiDB? db;
  if (config.dbEnabled) {
    db = await DatabaseFactory.create(DbConfig(
      type: DbType.postgres,
      host: config.dbHost,
      port: config.dbPort,
      database: config.dbName,
      username: config.dbUser,
      password: config.dbPassword,
      poolConfig: PoolConfig(maxConnections: config.dbPoolSize),
    ));
    await MigrationRunner(db).migrate();
  }

  // ── App ────────────────────────────────────────────────────────────────────
  final app = createApp(config, db: db);

  if (config.debug) {
    // ignore: avoid_print
    print('[{{projectName}}] env: ${Platform.environment['APP_ENV'] ?? 'dev'} | port: $port | db: ${config.dbEnabled} | shared: $shared');
  }

  app.onShutdown(() async {
    // ignore: avoid_print
    if (config.debug) print('[{{projectName}}] Shutting down...');
    await db?.close();
  });

  await app.start(port: port, shared: shared);
}

Map<String, String> _loadEnv() {
  final appEnv = Platform.environment['APP_ENV'] ?? 'dev';
  return mergeEnv([
    loadEnvFile('env/.env'),
    loadEnvFile('env/.env.$appEnv'),
  ]);
}
