import 'package:dartapi_core/dartapi_core.dart';
import 'package:dartapi_db/dartapi_db.dart';

import 'package:{{projectName}}/src/config/app_config.dart';
import 'package:{{projectName}}/src/controllers/auth_controller.dart';
import 'package:{{projectName}}/src/controllers/files_controller.dart';
import 'package:{{projectName}}/src/controllers/notifications_controller.dart';
import 'package:{{projectName}}/src/controllers/product_controller.dart';
import 'package:{{projectName}}/src/controllers/stats_controller.dart';
import 'package:{{projectName}}/src/controllers/user_controller.dart';
import 'package:{{projectName}}/src/controllers/ws_controller.dart';
import 'package:{{projectName}}/src/core/dartapi.dart';
import 'package:{{projectName}}/src/repositories/product_repository.dart';
import 'package:{{projectName}}/src/repositories/user_repository.dart';
import 'package:{{projectName}}/src/services/auth_service.dart';
import 'package:{{projectName}}/src/services/product_service.dart';
import 'package:{{projectName}}/src/services/user_service.dart';

/// Wires up every dependency via [DartAPI.register] and returns a fully
/// configured [DartAPI] instance.
///
/// Called from `bin/main.dart` after the DB connection (if any) is established.
/// Keeping all wiring here means `main.dart` stays small and every component
/// is testable in isolation by calling [createApp] directly in tests.
DartAPI createApp(AppConfig config, {DartApiDB? db}) {
  final app = DartAPI(
    corsOrigin: config.corsOrigin,
    appName: '{{projectName}}',
  );

  // ── Singletons ─────────────────────────────────────────────────────────────
  if (db != null) app.registerSingleton<DartApiDB>(db);

  // ── Repositories ───────────────────────────────────────────────────────────
  // InMemoryXxxRepository for dev/tests; DbXxxRepository when a DB is present.
  app.register<UserRepository>(
    (_) => db != null ? DbUserRepository(db) : InMemoryUserRepository(),
  );
  app.register<ProductRepository>(
    (_) => db != null ? DbProductRepository(db) : InMemoryProductRepository(),
  );

  // ── Auth ───────────────────────────────────────────────────────────────────
  // InMemoryTokenStore keeps revoked JTIs in-process.
  // Swap for a Redis-backed store in multi-instance or persistent deployments.
  app.register<InMemoryTokenStore>((_) => InMemoryTokenStore());
  app.register<JwtService>(
    (r) => JwtService(
      accessTokenSecret: config.jwtAccessSecret,
      refreshTokenSecret: config.jwtRefreshSecret,
      issuer: '{{projectName}}',
      audience: '{{projectName}}-users',
      tokenStore: r.get<InMemoryTokenStore>(),
    ),
  );

  // ── Services ───────────────────────────────────────────────────────────────
  app.register<AuthService>((r) => AuthService(jwtService: r.get<JwtService>()));
  app.register<UserService>((r) => UserService(repository: r.get<UserRepository>()));
  app.register<ProductService>((r) => ProductService(repository: r.get<ProductRepository>()));

  // ── Middleware ─────────────────────────────────────────────────────────────
  app.enableCompression();
  app.enableBackgroundTasks();
  app.enableTimeout(const Duration(seconds: 30));
  app.enableRateLimit(
    maxRequests: 200,
    window: const Duration(minutes: 1),
  );

  // ── Controllers ────────────────────────────────────────────────────────────
  app.addControllers([
    // Core CRUD + auth
    AuthController(
      authService: app.get<AuthService>(),
      jwtService: app.get<JwtService>(),
    ),
    UserController(
      userService: app.get<UserService>(),
      jwtService: app.get<JwtService>(),
    ),
    ProductController(
      productService: app.get<ProductService>(),
      jwtService: app.get<JwtService>(),
    ),
    // Streaming
    NotificationsController(jwtService: app.get<JwtService>()), // GET /notifications/stream (SSE)
    WsController(jwtService: app.get<JwtService>()),             // /ws/chat (WebSocket)
    // File uploads
    FilesController(jwtService: app.get<JwtService>()),          // POST /files/upload, GET /files
    // Admin (API key auth)
    StatsController(),                                            // GET /admin/stats, GET /admin/info
  ]);

  // ── Built-in endpoints ─────────────────────────────────────────────────────
  app.enableHealthCheck(); // GET /health
  app.enableMetrics();     // GET /metrics (Prometheus)
  app.enableDocs(title: '{{projectName}}', version: '1.0.0'); // GET /docs

  return app;
}
