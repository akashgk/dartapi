import 'dart:io';

import 'package:{{projectName}}/src/config/app_config.dart';
import 'package:{{projectName}}/src/config/env_loader.dart';
import 'package:{{projectName}}/src/controllers/auth_controller.dart';
import 'package:{{projectName}}/src/controllers/product_controller.dart';
import 'package:{{projectName}}/src/controllers/user_controller.dart';
import 'package:{{projectName}}/src/core/core.dart';
import 'package:{{projectName}}/src/repositories/product_repository.dart';
import 'package:{{projectName}}/src/repositories/user_repository.dart';
import 'package:{{projectName}}/src/services/auth_service.dart';
import 'package:{{projectName}}/src/services/product_service.dart';
import 'package:{{projectName}}/src/services/user_service.dart';
import 'package:dartapi_auth/dartapi_auth.dart';
import 'package:dartapi_db/dartapi_db.dart';

void main(List<String> args) async {
  // Determine the active environment (process var takes priority over .env).
  final appEnv = Platform.environment['APP_ENV'] ?? 'dev';

  // Load env/.env then env/.env.<appEnv>; Platform.environment always wins.
  final env = mergeEnv([
    loadEnvFile('env/.env'),
    loadEnvFile('env/.env.$appEnv'),
  ]);

  final config = AppConfig(environment: env);
  config.validateForProduction();

  // Allow --port / --port=N to override the configured port at startup.
  int port = config.port;
  for (var i = 0; i < args.length; i++) {
    if (args[i] == '--port' && i + 1 < args.length) {
      port = int.tryParse(args[i + 1]) ?? port;
      break;
    } else if (args[i].startsWith('--port=')) {
      port = int.tryParse(args[i].split('=')[1]) ?? port;
      break;
    }
  }

  if (config.debug) {
    print('[{{projectName}}] env    : $appEnv');
    print('[{{projectName}}] port   : $port');
    print('[{{projectName}}] db     : ${config.dbHost}:${config.dbPort}/${config.dbName}');
  }

  final db = await DatabaseFactory.create(DbConfig(
    type: DbType.postgres,
    host: config.dbHost,
    port: config.dbPort,
    database: config.dbName,
    username: config.dbUser,
    password: config.dbPassword,
    poolConfig: PoolConfig(maxConnections: config.dbPoolSize),
  ));

  final jwtService = JwtService(
    accessTokenSecret: config.jwtAccessSecret,
    refreshTokenSecret: config.jwtRefreshSecret,
    issuer: '{{projectName}}',
    audience: '{{projectName}}-users',
  );

  // Repositories — swap InMemory* for Db* variants to connect to your database.
  final userRepository = DbUserRepository(db);
  final productRepository = DbProductRepository(db);

  // Services
  final authService = AuthService(jwtService: jwtService);
  final userService = UserService(repository: userRepository);
  final productService = ProductService(repository: productRepository);

  final app = DartAPI(
    db: db,
    jwtService: jwtService,
    corsOrigin: config.corsOrigin,
  );

  app.addControllers([
    AuthController(authService: authService),
    UserController(userService: userService, jwtService: jwtService),
    ProductController(productService: productService, jwtService: jwtService),
  ]);

  app.enableDocs(title: '{{projectName}}', version: '1.0.0');
  app.enableHealthCheck();
  app.start(port: port);
}
