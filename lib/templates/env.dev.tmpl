APP_ENV=dev

PORT=8080
DEBUG=true
LOG_LEVEL=debug

# Set DB_ENABLED=true once you have a local PostgreSQL instance running.
# In-memory repositories are used when DB_ENABLED=false — no database needed.
DB_ENABLED=false

DB_HOST=localhost
DB_PORT=5432
DB_NAME={{projectName}}_dev
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_POOL_SIZE=5

JWT_ACCESS_SECRET=dev-access-secret-not-for-production
JWT_REFRESH_SECRET=dev-refresh-secret-not-for-production
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

CORS_ORIGIN=*
