import 'package:dartapi_core/dartapi_core.dart';

/// Demonstrates multipart file upload handling.
///
/// Upload a file:
/// ```
/// curl -X POST http://localhost:8080/files/upload \
///   -H "Authorization: Bearer <token>" \
///   -F "file=@photo.jpg"
/// ```
class FilesController extends BaseController {
  final JwtService? _jwtService;

  // In-memory store. Replace with S3 / GCS / local disk in production.
  static final List<Map<String, dynamic>> _store = [];

  FilesController({JwtService? jwtService}) : _jwtService = jwtService;

  @override
  List<ApiRoute> get routes => [_uploadApi(), _listApi()];

  ApiRoute<void, Map<String, dynamic>> _uploadApi() => ApiRoute(
        method: ApiMethod.post,
        path: '/files/upload',
        typedHandler: _upload,
        middlewares: [if (_jwtService != null) authMiddleware(_jwtService)],
        summary: 'Upload a file (multipart/form-data)',
        description:
            'Accepts a single `file` field. '
            'Returns the stored file metadata.',
        security: _jwtService != null ? [SecurityScheme.bearer] : [],
      );

  ApiRoute<void, List<Map<String, dynamic>>> _listApi() => ApiRoute(
        method: ApiMethod.get,
        path: '/files',
        typedHandler: _list,
        middlewares: [if (_jwtService != null) authMiddleware(_jwtService)],
        summary: 'List uploaded files',
        security: _jwtService != null ? [SecurityScheme.bearer] : [],
      );

  Future<Map<String, dynamic>> _upload(Request req, void _) async {
    if (!req.isMultipart) {
      throw const ApiException(400, 'Expected multipart/form-data');
    }

    final file = await req.file('file');
    if (file == null) throw const ApiException(400, 'Missing "file" field');

    final bytes = file.bytes;
    final meta = {
      'id': _store.length + 1,
      'filename': file.filename ?? 'unknown',
      'size': bytes.length,
      'mimeType': file.contentType,
      'uploadedAt': DateTime.now().toIso8601String(),
    };
    _store.add(meta);

    // Background task: fires after the 201 response is sent.
    req.backgroundTasks.add(() async {
      // ignore: avoid_print
      print('[bg] File stored: ${meta['filename']} (${meta['size']} bytes)');
    });

    return meta;
  }

  Future<List<Map<String, dynamic>>> _list(Request req, void _) async =>
      List.unmodifiable(_store);
}
