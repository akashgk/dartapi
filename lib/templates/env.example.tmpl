# {{projectName}} — environment variable reference
# Copy this file to .env and fill in your values.
# Never commit .env or .env.<environment> files — they contain secrets.

# ── Runtime environment ────────────────────────────────────────────────────
# Options: dev | staging | uat | production
APP_ENV=dev

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8080
DEBUG=true
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Set to true to connect to a real database. When false, in-memory
# repositories are used — useful for local dev without a running DB.
DB_ENABLED=false

DB_HOST=localhost
DB_PORT=5432
DB_NAME={{projectName}}_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_POOL_SIZE=10

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-before-deploying
JWT_REFRESH_SECRET=change-me-before-deploying
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# ── CORS ───────────────────────────────────────────────────────────────────
# Use * to allow all origins (dev only). Set to your domain in production.
CORS_ORIGIN=*
