import 'package:dartapi_db/dartapi_db.dart';
import '../models/user.dart';

abstract class UserRepository {
  Future<List<User>> findAll({int page = 1, int limit = 20});
  Future<User?> findById(int id);
  Future<User?> findByEmail(String email);
  Future<User> create(User user);
}

/// In-memory repository — ships with the project for local dev and tests.
/// Swap for [DbUserRepository] in [main.dart] when you have a real database.
class InMemoryUserRepository implements UserRepository {
  final List<User> _store = [
    const User(id: 1, name: 'Alice', age: 30, email: 'alice@example.com'),
    const User(id: 2, name: 'Bob', age: 25, email: 'bob@example.com'),
  ];
  int _nextId = 3;

  @override
  Future<List<User>> findAll({int page = 1, int limit = 20}) async {
    final offset = (page - 1) * limit;
    return _store.skip(offset).take(limit).toList();
  }

  @override
  Future<User?> findById(int id) async {
    for (final u in _store) {
      if (u.id == id) return u;
    }
    return null;
  }

  @override
  Future<User?> findByEmail(String email) async {
    for (final u in _store) {
      if (u.email == email) return u;
    }
    return null;
  }

  @override
  Future<User> create(User user) async {
    final created = User(
      id: _nextId++,
      name: user.name,
      age: user.age,
      email: user.email,
    );
    _store.add(created);
    return created;
  }
}

/// PostgreSQL-backed repository. Used in production via [main.dart].
class DbUserRepository implements UserRepository {
  final DartApiDB _db;
  DbUserRepository(this._db);

  @override
  Future<List<User>> findAll({int page = 1, int limit = 20}) async {
    final result = await _db.select('users');
    final offset = (page - 1) * limit;
    return result.rows.skip(offset).take(limit).map(User.fromRow).toList();
  }

  @override
  Future<User?> findById(int id) async {
    final result = await _db.select('users', where: {'id': id});
    return result.isEmpty ? null : User.fromRow(result.rows.first);
  }

  @override
  Future<User?> findByEmail(String email) async {
    final result = await _db.select('users', where: {'email': email});
    return result.isEmpty ? null : User.fromRow(result.rows.first);
  }

  @override
  Future<User> create(User user) async {
    final result = await _db.insert('users', {
      'name': user.name,
      'age': user.age,
      'email': user.email,
    });
    return User.fromRow(result.rows.first);
  }
}
