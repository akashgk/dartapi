import 'package:dartapi_core/dartapi_core.dart';

class UserDTO {
  static final fields = FieldSet({
    'name': Field<String>(
      validators: [NotEmptyValidator(), MaxLengthValidator(100)],
      example: 'Alice',
    ),
    'email': Field<String>(
      validators: [EmailValidator()],
      example: 'alice@example.com',
    ),
    'age': Field<int>(
      validators: [RangeValidator<int>(min: 0, max: 150)],
      example: 30,
    ),
  });

  final String name;
  final int age;
  final String email;

  const UserDTO({required this.name, required this.age, required this.email});

  factory UserDTO.fromJson(Map<String, dynamic> json) {
    fields.validate(json);
    return UserDTO(
      name: json['name'] as String,
      age: json['age'] as int,
      email: json['email'] as String,
    );
  }

  static Map<String, dynamic> get schema => fields.toJsonSchema();
}
