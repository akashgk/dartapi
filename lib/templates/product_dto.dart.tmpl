import 'package:dartapi_core/dartapi_core.dart';

class ProductDto implements Serializable {
  static final fields = FieldSet({
    'name': Field<String>(
      validators: [NotEmptyValidator()],
      example: 'Keyboard',
    ),
    'price': Field<double>(
      validators: [RangeValidator<double>(min: 0)],
      example: 29.99,
    ),
    'quantity': Field<int>(
      validators: [RangeValidator<int>(min: 0)],
      example: 15,
    ),
  });

  final int? id;
  final String name;
  final double price;
  final int quantity;

  ProductDto({
    this.id,
    required this.name,
    required this.price,
    required this.quantity,
  });

  factory ProductDto.fromJson(Map<String, dynamic> json) {
    fields.validate(json);
    return ProductDto(
      name: json['name'] as String,
      price: (json['price'] as num).toDouble(),
      quantity: json['quantity'] as int,
    );
  }

  factory ProductDto.fromRow(Map<String, dynamic> row) {
    return ProductDto(
      id: row.verifyKey<int>('id'),
      name: row.verifyKey<String>('name'),
      price: _parsePrice(row['price']),
      quantity: row.verifyKey<int>('quantity'),
    );
  }

  static double _parsePrice(dynamic value) {
    if (value is num) return value.toDouble();
    if (value is String) return double.tryParse(value) ?? 0.0;
    throw Exception('Invalid type for key "price": ${value.runtimeType}');
  }

  @override
  Map<String, dynamic> toJson() => {
        if (id != null) 'id': id,
        'name': name,
        'price': price,
        'quantity': quantity,
      };

  static Map<String, dynamic> get schema => fields.toJsonSchema();
}
