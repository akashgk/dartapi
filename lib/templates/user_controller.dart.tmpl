import 'package:shelf/shelf.dart';
import 'package:dartapi_auth/dartapi_auth.dart';
import 'package:dartapi_core/dartapi_core.dart';
import 'package:{{projectName}}/src/dto/user_dto.dart';
import 'package:{{projectName}}/src/models/user.dart';
import 'package:{{projectName}}/src/services/user_service.dart';

class UserController extends BaseController {
  final UserService _userService;
  final JwtService _jwtService;

  UserController({
    required UserService userService,
    required JwtService jwtService,
  })  : _userService = userService,
        _jwtService = jwtService;

  @override
  List<ApiRoute> get routes => [_listApi(), _getApi(), _createApi()];

  ApiRoute<void, List<User>> _listApi() => ApiRoute(
        method: ApiMethod.get,
        path: '/users',
        typedHandler: _list,
        middlewares: [authMiddleware(_jwtService)],
        summary: 'List users',
        description:
            'Returns a paginated list of users. Supports ?page and ?limit.',
        responseSchema: {
          'type': 'array',
          'items': {
            'type': 'object',
            'properties': {
              'id': {'type': 'integer'},
              'name': {'type': 'string'},
              'age': {'type': 'integer'},
              'email': {'type': 'string'},
            },
          },
        },
      );

  ApiRoute<void, User> _getApi() => ApiRoute(
        method: ApiMethod.get,
        path: '/users/<id>',
        typedHandler: _get,
        middlewares: [authMiddleware(_jwtService)],
        summary: 'Get user',
        description: 'Returns a single user by ID.',
      );

  ApiRoute<UserDTO, User> _createApi() => ApiRoute(
        method: ApiMethod.post,
        path: '/users',
        statusCode: 201,
        typedHandler: _create,
        dtoParser: UserDTO.fromJson,
        middlewares: [authMiddleware(_jwtService)],
        summary: 'Create user',
        description: 'Creates a new user.',
        requestSchema: UserDTO.schema,
      );

  Future<List<User>> _list(Request req, void _) => _userService.getUsers(
        page: req.queryParam<int>('page') ?? 1,
        limit: req.queryParam<int>('limit') ?? 20,
      );

  Future<User> _get(Request req, void _) =>
      _userService.getUser(req.pathParam<int>('id'));

  Future<User> _create(Request req, UserDTO? dto) =>
      _userService.createUser(dto!);
}
