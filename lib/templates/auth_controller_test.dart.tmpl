import 'package:test/test.dart';
import 'package:dartapi_auth/dartapi_auth.dart';
import 'package:dartapi_core/dartapi_core.dart';
import 'package:{{projectName}}/src/dto/login_dto.dart';
import 'package:{{projectName}}/src/services/auth_service.dart';

void main() {
  late JwtService jwtService;
  late AuthService authService;

  setUp(() {
    jwtService = JwtService(
      accessTokenSecret: 'test-access-secret-32-chars-long!!',
      refreshTokenSecret: 'test-refresh-secret-32-chars-long!',
      issuer: 'test',
      audience: 'test-users',
    );
    authService = AuthService(jwtService: jwtService);
  });

  group('AuthService', () {
    group('login', () {
      test('valid credentials return non-empty tokens', () {
        final dto =
            LoginDTO(username: 'admin@example.com', password: 'password');
        final result = authService.login(dto);
        expect(result.accessToken, isNotEmpty);
        expect(result.refreshToken, isNotEmpty);
      });

      test('invalid credentials throw 401', () {
        expect(
          () => authService.login(
              LoginDTO(username: 'bad@example.com', password: 'wrong')),
          throwsA(
            isA<ApiException>()
                .having((e) => e.statusCode, 'statusCode', 401),
          ),
        );
      });

      test('access and refresh tokens are different strings', () {
        final result = authService.login(
            LoginDTO(username: 'admin@example.com', password: 'password'));
        expect(result.accessToken, isNot(equals(result.refreshToken)));
      });
    });

    group('refresh', () {
      test('valid refresh token returns a new access token', () async {
        final tokens = authService.login(
            LoginDTO(username: 'admin@example.com', password: 'password'));
        final refreshed = await authService.refresh(tokens.refreshToken);
        expect(refreshed.accessToken, isNotEmpty);
        expect(refreshed.refreshToken, equals(tokens.refreshToken));
      });

      test('invalid refresh token throws 401', () async {
        expect(
          () => authService.refresh('invalid.token.here'),
          throwsA(
            isA<ApiException>()
                .having((e) => e.statusCode, 'statusCode', 401),
          ),
        );
      });
    });

    group('logout', () {
      test('revoked access token is no longer accepted', () async {
        final tokens = authService.login(
            LoginDTO(username: 'admin@example.com', password: 'password'));

        // Revoke the token
        await authService.logout(tokens.accessToken);

        // A revoked token should fail verification
        final payload =
            await jwtService.verifyAccessToken(tokens.accessToken);
        expect(payload, isNull);
      });

      test('logout does not throw for a valid token', () async {
        final tokens = authService.login(
            LoginDTO(username: 'admin@example.com', password: 'password'));
        await expectLater(
          authService.logout(tokens.accessToken),
          completes,
        );
      });
    });
  });
}
