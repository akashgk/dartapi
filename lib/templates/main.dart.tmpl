/// Entry point for additional isolates spawned by `dartapi run --isolates=N`.
/// Each isolate independently builds the full application and binds to the
/// shared port — the OS load-balances connections across all of them.
Future<void> _isolateEntry(int port) => _startApp(port, shared: true);

Future<void> main(List<String> args) async {
  // ── Environment ────────────────────────────────────────────────────────────
  final appEnv = Platform.environment['APP_ENV'] ?? 'dev';

  // Load base .env then environment-specific override.
  // Platform.environment always wins over file values.
  final env = mergeEnv([
    loadEnvFile('env/.env'),
    loadEnvFile('env/.env.$appEnv'),
  ]);

  final config = AppConfig(environment: env);
  config.validateForProduction(); // Warns if dev placeholder secrets are used.

  // ── Port ───────────────────────────────────────────────────────────────────
  // Priority: --port flag > PORT env var > config default (8080)
  int port = config.port;
  for (var i = 0; i < args.length; i++) {
    if (args[i] == '--port' && i + 1 < args.length) {
      port = int.tryParse(args[i + 1]) ?? port;
      break;
    } else if (args[i].startsWith('--port=')) {
      port = int.tryParse(args[i].split('=')[1]) ?? port;
      break;
    }
  }

  // ── Multi-core ─────────────────────────────────────────────────────────────
  // Set ISOLATES=N (via `dartapi run --isolates=N`) to spawn N Dart isolates
  // bound to the same port. Each gets its own event loop and DB connections.
  final isolates = int.tryParse(Platform.environment['ISOLATES'] ?? '1') ?? 1;

  if (isolates > 1) {
    for (var i = 0; i < isolates - 1; i++) {
      await Isolate.spawn(_isolateEntry, port);
    }
  }

  await _startApp(port, shared: isolates > 1);
}

Future<void> _startApp(int port, {bool shared = false}) async {
  final appEnv = Platform.environment['APP_ENV'] ?? 'dev';

  final env = mergeEnv([
    loadEnvFile('env/.env'),
    loadEnvFile('env/.env.$appEnv'),
  ]);

  final config = AppConfig(environment: env);

  if (config.debug) {
    print('[{{projectName}}] env      : $appEnv');
    print('[{{projectName}}] port     : $port');
    print('[{{projectName}}] db       : ${config.dbHost}:${config.dbPort}/${config.dbName}');
    print('[{{projectName}}] shared   : $shared');
  }

  // ── Database ───────────────────────────────────────────────────────────────
  // Swap DbType.postgres for DbType.mysql or DbType.sqlite as needed.
  // For quick local dev without a database, comment this out and use
  // InMemory* repositories instead (no migrations needed).
  final db = await DatabaseFactory.create(DbConfig(
    type: DbType.postgres,
    host: config.dbHost,
    port: config.dbPort,
    database: config.dbName,
    username: config.dbUser,
    password: config.dbPassword,
    poolConfig: PoolConfig(maxConnections: config.dbPoolSize),
  ));

  // Run all pending *.sql files in migrations/ on every startup.
  // Already-applied migrations are tracked in _dartapi_migrations and skipped.
  await MigrationRunner(db).run();

  // ── Auth ───────────────────────────────────────────────────────────────────
  // InMemoryTokenStore keeps revoked JTIs in-process.
  // Replace with a Redis or database-backed store for multi-instance deployments
  // or to survive server restarts.
  final tokenStore = InMemoryTokenStore();

  final jwtService = JwtService(
    accessTokenSecret: config.jwtAccessSecret,
    refreshTokenSecret: config.jwtRefreshSecret,
    issuer: '{{projectName}}',
    audience: '{{projectName}}-users',
    tokenStore: tokenStore,
  );

  // ── Repositories ───────────────────────────────────────────────────────────
  // Swap Db* for InMemory* to develop locally without a database.
  final userRepository = DbUserRepository(db);
  final productRepository = DbProductRepository(db);

  // ── Services ───────────────────────────────────────────────────────────────
  final authService = AuthService(jwtService: jwtService);
  final userService = UserService(repository: userRepository);
  final productService = ProductService(repository: productRepository);

  // ── App ────────────────────────────────────────────────────────────────────
  final app = DartAPI(
    db: db,
    jwtService: jwtService,
    corsOrigin: config.corsOrigin,
  );

  // ── Middleware ─────────────────────────────────────────────────────────────
  // requestIdMiddleware and globalExceptionMiddleware are always active.
  // The methods below opt-in to additional production middleware.
  app.enableCompression();                          // Gzip responses > 1 KB
  app.enableBackgroundTasks();                      // async post-response work
  app.enableTimeout(const Duration(seconds: 30));   // 408 on hung handlers
  app.enableRateLimit(
    maxRequests: 200,
    window: const Duration(minutes: 1),
    // Key by authenticated user ID when available; fall back to IP:
    // keyExtractor: (req) => req.context['userId']?.toString() ?? req.headers['x-forwarded-for'] ?? 'unknown',
  );

  // ── Controllers ────────────────────────────────────────────────────────────
  app.addControllers([
    AuthController(authService: authService, jwtService: jwtService),
    UserController(userService: userService, jwtService: jwtService),
    ProductController(productService: productService, jwtService: jwtService),
  ]);

  // ── Built-in endpoints ─────────────────────────────────────────────────────
  app.enableHealthCheck();                                   // GET /health
  app.enableMetrics();                                       // GET /metrics
  app.enableDocs(title: '{{projectName}}', version: '1.0.0'); // GET /docs

  // ── Hooks ──────────────────────────────────────────────────────────────────
  app.onStartup(() async {
    if (config.debug) print('[{{projectName}}] Startup complete.');
  });

  app.onShutdown(() async {
    if (config.debug) print('[{{projectName}}] Closing database pool...');
    await db.close();
  });

  await app.start(port: port, shared: shared);
}
