import 'package:dartapi_core/dartapi_core.dart';

class LoginDTO {
  static final fields = FieldSet({
    'username': Field<String>(validators: [EmailValidator()]),
    'password': Field<String>(validators: [MinLengthValidator(6)]),
  });

  final String username;
  final String password;

  LoginDTO({required this.username, required this.password});

  factory LoginDTO.fromJson(Map<String, dynamic> json) {
    fields.validate(json);
    return LoginDTO(
      username: json['username'] as String,
      password: json['password'] as String,
    );
  }

  static Map<String, dynamic> get schema => fields.toJsonSchema();
}
